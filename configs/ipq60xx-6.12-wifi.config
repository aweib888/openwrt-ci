# CONFIG_PACKAGE_luci-app-passwall is not set    #PassWall管理界面
# CONFIG_PACKAGE_luci-i18n-passwall-zh-cn is not set    #中文翻译
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set    #禁用Haproxy
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set    #禁用SS Rust客户端
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server is not set    #禁用SS Rust服务端
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set    #禁用简单混淆
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus is not set    #禁用Trojan Plus
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geoview is not set    #禁用V2Ray GeoIP
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set    #禁用V2Ray插件
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set    #禁用Xray

# LuCI 应用 - 其他功能
CONFIG_PACKAGE_luci-app-netspeedtest=y    #网络测速
CONFIG_PACKAGE_luci-app-package-manager=y    #包管理器
CONFIG_PACKAGE_luci-app-sqm=y    #智能QoS
CONFIG_PACKAGE_luci-app-ttyd=y    #网页终端
CONFIG_PACKAGE_luci-app-upnp=y    #UPnP端口映射
CONFIG_PACKAGE_luci-app-athena-led=m    #LED灯控制

# LuCI 国际化中文翻译
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m    #LED灯中文
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y    #基础中文
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y    #DDNS中文
# CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn is not set    #Docker中文
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y    #防火墙中文
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y    #包管理器中文
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y    #SQM中文
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y    #TTYD中文
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y    #UPnP中文
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y    #WOL中文

# MicroSOCKS 代理
# CONFIG_PACKAGE_microsocks is not set    #轻量级SOCKS5代理

# MiniUPnPd UPnP守护进程
CONFIG_PACKAGE_miniupnpd-nftables=y    #nftables版UPnP

# 挂载工具
CONFIG_PACKAGE_mount-utils=m    #挂载辅助工具
CONFIG_PACKAGE_resolveip=m    #IP地址解析

# Samba4 Windows文件共享（全部移除）
# CONFIG_PACKAGE_samba4-libs is not set
# CONFIG_PACKAGE_samba4-server is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_wsdd2 is not set
# CONFIG_SAMBA4_SERVER_AVAHI is not set
# CONFIG_SAMBA4_SERVER_NETBIOS is not set
# CONFIG_SAMBA4_SERVER_VFS is not set
# CONFIG_SAMBA4_SERVER_WSDD2 is not set
# CONFIG_PACKAGE_luci-i18n-samba4-zh-cn is not set    #Samba4中文

# SQM 智能队列管理
CONFIG_PACKAGE_sqm-scripts=y    #SQM脚本
CONFIG_PACKAGE_tc-tiny=y    #流量控制工具

# 网络工具
CONFIG_PACKAGE_tcping=m    #TCP Ping测试
CONFIG_PACKAGE_unzip=m    #ZIP解压

# TTYD 网页终端
CONFIG_PACKAGE_ttyd=y    #浏览器访问命令行

# Xray-Core 代理核心
# CONFIG_PACKAGE_xray-core is not set    #V2Ray继任者

# xtables-nft 兼容层
CONFIG_PACKAGE_xtables-nft=y    #iptables规则运行在nftables上

# ZeroTier 虚拟组网
CONFIG_PACKAGE_zerotier=m    #跨地域虚拟局域网
CONFIG_PACKAGE_luci-app-zerotier=m    #ZeroTier VPN
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=m    #ZeroTier中文

# EasyTier 虚拟组网
CONFIG_PACKAGE_easytier=m                #EasyTier核心（P2P SD-WAN）
CONFIG_PACKAGE_luci-app-easytier=m       #EasyTier LuCI管理界面
CONFIG_PACKAGE_luci-i18n-easytier-zh-cn=m  #中文翻译（如feed提供）

# Boost 编译选项
CONFIG_boost-compile-visibility-hidden=y    #隐藏符号
CONFIG_boost-runtime-shared=y    #运行时共享库
CONFIG_boost-static-and-shared-libs=y    #静态+动态库
CONFIG_boost-variant-release=y    #Release版本

# 禁用的选项
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set    #禁用initramfs镜像
# CONFIG_PACKAGE_kmod-crypto-kpp is not set    #禁用密钥协商协议
