#=y  编译进固件，内置到rootfs，必装
#=m  编译成独立ipk安装包，不打进主固件，只生成插件包
#=n  不编译，彻底不生成

# 设备平台
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 允许自定义 BusyBox 里各工具的开关
CONFIG_BUSYBOX_CUSTOM=y
# CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6 is not set
CONFIG_BUSYBOX_CONFIG_LSUSB=y

# 设备列表
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7500=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

# 设备内存相关 (256M 内存优化)
CONFIG_IPQ_MEM_PROFILE_256=y
CONFIG_ATH11K_MEM_PROFILE_256M=y
CONFIG_KERNEL_IPQ_MEM_PROFILE=256

# 修复 6.12 内核非交互式编译报错的关键项
CONFIG_ALLOC_SKB_PAGE_FRAG_DISABLE=n

# CoreMark 跑分工具（彻底删除）
CONFIG_COREMARK_ENABLE_MULTITHREADING=n
CONFIG_COREMARK_OPTIMIZE_O3=n
CONFIG_PACKAGE_coremark=n

# Docker（完全移除）
CONFIG_DOCKER_CGROUP_OPTIONS=n
CONFIG_DOCKER_NET_MACVLAN=n
CONFIG_DOCKER_OPTIONAL_FEATURES=n
CONFIG_DOCKER_STO_EXT4=n

# GnuTLS 极限精简
CONFIG_GNUTLS_ALPN=y
CONFIG_GNUTLS_ANON=y
CONFIG_GNUTLS_DTLS_SRTP=y
CONFIG_GNUTLS_HEARTBEAT=y
CONFIG_GNUTLS_OCSP=y
CONFIG_GNUTLS_PSK=y

# I/O 调度
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y

# libcurl 精简（只保留 HTTP/HTTPS 路由必需项）
CONFIG_LIBCURL_COOKIES=n
CONFIG_LIBCURL_CRYPTO_AUTH=n
CONFIG_LIBCURL_FILE=n
CONFIG_LIBCURL_FTP=n
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_NGHTTP2=n
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_PROXY=n
CONFIG_LIBCURL_TFTP=n
CONFIG_LIBCURL_THREADED_RESOLVER=n
CONFIG_LIBCURL_TLS_SRP=n
CONFIG_LIBCURL_UNIX_SOCKETS=n

# LuCI 中文支持
CONFIG_LUCI_LANG_zh_Hans=y

# NSS 硬件加速底层硬开关
CONFIG_NSS_DRV_IGS_ENABLE=y
CONFIG_NSS_DRV_L2TP_ENABLE=y
CONFIG_NSS_DRV_LAG_ENABLE=y
CONFIG_NSS_DRV_MAPT_ENABLE=y
CONFIG_NSS_DRV_PPTP_ENABLE=y
CONFIG_NSS_DRV_PVXLAN_ENABLE=y
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_VXLAN_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y

# IPv6 过渡技术
CONFIG_PACKAGE_6rd=y

# 文件系统扩展属性工具
CONFIG_PACKAGE_attr=m

# 块设备挂载 (U盘/硬盘)
CONFIG_PACKAGE_block-mount=y

# Boost C++ 库 (改为动态包，精简主固件体积)
CONFIG_PACKAGE_boost=m
# CONFIG_PACKAGE_boost-program_options is not set
# CONFIG_PACKAGE_boost-system is not set

# Btrfs 文件系统（若不需要可改为 n，此处依你原样保留为插件）
CONFIG_PACKAGE_btrfs-progs=m
CONFIG_PACKAGE_kmod-fs-btrfs=m
CONFIG_PACKAGE_kmod-lib-raid6=m
CONFIG_PACKAGE_kmod-lib-xor=m
CONFIG_PACKAGE_kmod-lib-zstd=m

# CA 证书
CONFIG_PACKAGE_ca-certificates=m

# CGI-I/O 接口
CONFIG_PACKAGE_cgi-io=y

# ChinaDNS-NG 防污染
CONFIG_PACKAGE_chinadns-ng=y

# Coreutils GNU工具集
CONFIG_PACKAGE_coreutils=m
CONFIG_PACKAGE_coreutils-base64=m
CONFIG_PACKAGE_coreutils-nohup=m

# Curl 网络传输
CONFIG_PACKAGE_curl=m

# DBus 消息总线
CONFIG_PACKAGE_dbus=m

# DDNS 动态域名解析
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_luci-app-ddns=y

# 默认设置
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y

# DNS 代理/转发
CONFIG_PACKAGE_dns2socks=m
CONFIG_PACKAGE_dns2tcp=m

# 网络唤醒
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_luci-app-wol=y

# 防火墙
CONFIG_PACKAGE_firewall=m
CONFIG_PACKAGE_luci-app-firewall=y

# IP地理信息查看
CONFIG_PACKAGE_geoview=m

# Hysteria 代理
CONFIG_PACKAGE_hysteria=m

# IP 工具集
CONFIG_PACKAGE_ip-full=m
CONFIG_PACKAGE_ip-tiny=y

# IPv6 防火墙
CONFIG_PACKAGE_ip6tables-nft=m
CONFIG_PACKAGE_kmod-ip6tables=m

# Iperf3 网络测速
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_libperf3=y

# ipt2socks 代理转发
CONFIG_PACKAGE_ipt2socks=m

# iptables 扩展与全锥形 NAT (核心网络加速依赖)
CONFIG_PACKAGE_iptables-mod-extra=m
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_iptables-nft=y

# 内核模块 - 网络功能
CONFIG_PACKAGE_kmod-bonding=y
CONFIG_PACKAGE_kmod-dummy=m
CONFIG_PACKAGE_kmod-gre6=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-ip6-tunnel=y
CONFIG_PACKAGE_kmod-sit=y
CONFIG_PACKAGE_kmod-macvlan=m
CONFIG_PACKAGE_kmod-vxlan=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-netlink-diag=y

# 内核模块 - 加密/压缩
CONFIG_PACKAGE_kmod-crypto-acompress=y
CONFIG_PACKAGE_kmod-crypto-blake2b=m
CONFIG_PACKAGE_kmod-crypto-crc32=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y
CONFIG_PACKAGE_kmod-crypto-xxhash=m
CONFIG_PACKAGE_kmod-lib-lzo=y
CONFIG_PACKAGE_kmod-lib-xxhash=m
CONFIG_PACKAGE_kmod-lib-zlib-deflate=m
CONFIG_PACKAGE_kmod-lib-zlib-inflate=m

# 内核模块 - 文件系统支持
CONFIG_PACKAGE_kmod-fs-exportfs=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-xfs=y

# 内核模块 - iptables/netfilter 基础链
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=m
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=m
CONFIG_PACKAGE_kmod-ipt-physdev=m
CONFIG_PACKAGE_kmod-iptunnel4=y
CONFIG_PACKAGE_kmod-iptunnel6=y
CONFIG_PACKAGE_kmod-nat46=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_kmod-nf-ipt6=m
CONFIG_PACKAGE_kmod-nf-ipvs=m
CONFIG_PACKAGE_kmod-nf-nat6=m
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# 内核模块 - 字符集
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# 内核模块 - QCA NSS 高通硬加速核心驱动（必须保留）
CONFIG_PACKAGE_kmod-qca-mcs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=y

# 内核模块 - QoS/流量整形
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y

# 内核模块 - USB 存储支持
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-usb-dwc2=y
CONFIG_PACKAGE_kmod-usb-dwc2-pci=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-ohci-pci=y
CONFIG_PACKAGE_kmod-usb-phy-nop=y
CONFIG_PACKAGE_kmod-usb-roles=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb2-pci=y

# ZRAM 内存压缩 (256M内存设备福音)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# 基础依赖库
CONFIG_PACKAGE_libatomic=y
CONFIG_PACKAGE_libattr=m
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libelf=m
CONFIG_PACKAGE_libexpat=m
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libuv=y
CONFIG_PACKAGE_libwebsockets-full=y

# 网络相关库
CONFIG_PACKAGE_libavahi-client=m
CONFIG_PACKAGE_libcurl=m
CONFIG_PACKAGE_libdaemon=m
CONFIG_PACKAGE_libgnutls=m
CONFIG_PACKAGE_libip4tc=y
CONFIG_PACKAGE_libip6tc=y
CONFIG_PACKAGE_libiptext=y
CONFIG_PACKAGE_libiptext-nft=y
CONFIG_PACKAGE_libiptext6=y
CONFIG_PACKAGE_libxtables=y
CONFIG_PACKAGE_libminiupnpc=y
CONFIG_PACKAGE_libnatpmp=y
CONFIG_PACKAGE_libnghttp2=m
CONFIG_PACKAGE_libtasn1=m
CONFIG_PACKAGE_libtirpc=m

# 系统工具库
CONFIG_PACKAGE_libdbus=m
CONFIG_PACKAGE_liblzo=m
CONFIG_PACKAGE_libmount=m
CONFIG_PACKAGE_libpopt=m
CONFIG_PACKAGE_libreadline=m
CONFIG_PACKAGE_libseccomp=m
CONFIG_PACKAGE_liburing=m

# LuCI 核心依赖
CONFIG_PACKAGE_liblucihttp=y
CONFIG_PACKAGE_liblucihttp-lua=y
CONFIG_PACKAGE_liblucihttp-ucode=y
CONFIG_PACKAGE_libubus-lua=y
CONFIG_PACKAGE_libuci-lua=m

# Lua 脚本语言
CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_ucode-mod-lua=y

# LuCI Web 管理界面核心
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-file=y
CONFIG_PACKAGE_rpcd-mod-iwinfo=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_rpcd-mod-ucode=y
CONFIG_PACKAGE_ucode-mod-html=y
CONFIG_PACKAGE_ucode-mod-math=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

# LuCI 应用 - Argon 主题配置
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# LuCI 应用 - 常用工具
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-athena-led=m

# LuCI 国际化中文翻译
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y

# MiniUPnPd 防火墙集成
CONFIG_PACKAGE_miniupnpd-nftables=y

# 挂载工具
CONFIG_PACKAGE_mount-utils=m
CONFIG_PACKAGE_resolveip=m

# SQM 智能队列管理 (QoS)
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_tc-tiny=y

# 网络辅助工具
CONFIG_PACKAGE_tcping=m
CONFIG_PACKAGE_unzip=m

# TTYD 网页终端
CONFIG_PACKAGE_ttyd=y

# nftables 兼容层
CONFIG_PACKAGE_xtables-nft=y

# 虚拟组网工具 (保持为离线包，不打入固件以节省体积)
CONFIG_PACKAGE_zerotier=m
CONFIG_PACKAGE_luci-app-zerotier=m
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=m
CONFIG_PACKAGE_easytier=m
CONFIG_PACKAGE_luci-app-easytier=m
CONFIG_PACKAGE_luci-i18n-easytier-zh-cn=m

# Boost 编译选项优化
CONFIG_boost-compile-visibility-hidden=y
CONFIG_boost-runtime-shared=y
CONFIG_boost-static-and-shared-libs=y
CONFIG_boost-variant-release=y
