#=y  编译进固件，内置到rootfs，必装
#=m  编译成独立ipk安装包，不打进主固件，只生成插件包
#=n  不编译，彻底不生成

#设备平台
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

#生成多设备时需要
# CONFIG_TARGET_MULTI_PROFILE is not set
# CONFIG_TARGET_PER_DEVICE_ROOTFS is not set

#允许你自定义 BusyBox 里各工具的开关
CONFIG_BUSYBOX_CUSTOM=y
# CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6 is not set
CONFIG_BUSYBOX_CONFIG_LSUSB=y

#设备列表
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7500=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

#设备内存相关
# CONFIG_ATH11K_MEM_PROFILE_1G is not set
# CONFIG_IPQ_MEM_PROFILE_1024 is not set
# CONFIG_ATH11K_MEM_PROFILE_512M is not set
# CONFIG_IPQ_MEM_PROFILE_512 is not set
CONFIG_IPQ_MEM_PROFILE_256=y
CONFIG_ATH11K_MEM_PROFILE_256M=y
CONFIG_KERNEL_IPQ_MEM_PROFILE=256

#CoreMark 跑分工具（纯测试用，删掉）
CONFIG_COREMARK_ENABLE_MULTITHREADING=n
#CONFIG_COREMARK_NUMBER_OF_THREADS=16
CONFIG_COREMARK_OPTIMIZE_O3=n
CONFIG_PACKAGE_coremark=n

#Docker（完全移除）
CONFIG_DOCKER_CGROUP_OPTIONS=n
CONFIG_DOCKER_NET_MACVLAN=n
CONFIG_DOCKER_OPTIONAL_FEATURES=n
CONFIG_DOCKER_STO_EXT4=n

#GnuTLS（可精简350k,除非有特定依赖包，否则全关）
CONFIG_GNUTLS_ALPN=y
CONFIG_GNUTLS_ANON=y
CONFIG_GNUTLS_DTLS_SRTP=y
CONFIG_GNUTLS_HEARTBEAT=y
CONFIG_GNUTLS_OCSP=y
CONFIG_GNUTLS_PSK=y

# ---------- Linux 内核最小化（仅保留路由必需项） ----------
# --- Cgroup：仅保留 device（systemd/procd 需要），其余全关 ---
CONFIG_KERNEL_CGROUP_DEVICE=y              # 保留，基础兼容
CONFIG_KERNEL_CGROUP_FREEZER=n             # 关
CONFIG_KERNEL_CGROUP_HUGETLB=n             # 关
CONFIG_KERNEL_CGROUP_NET_PRIO=n            # 关
CONFIG_KERNEL_CGROUP_PERF=n                # 关
CONFIG_KERNEL_NET_CLS_CGROUP=n             # 关
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=n         # 关

# --- 大页内存（Hugetlb/THP）：Docker 才需要，路由关掉 ---
CONFIG_KERNEL_HUGETLBFS=n                  # 关
CONFIG_KERNEL_HUGETLB_PAGE=n               # 关
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=n       # 关
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=n # 关

# --- 性能调试：路由日常用不到，全关 ---
CONFIG_KERNEL_PERF_EVENTS=n                # 关
CONFIG_KERNEL_ARM_PMU=n                    # 关

# --- I/O 调度：也可用 mq-deadline 替代 CFQ ---
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y

# --- zRAM：若内存≥512MB 可关，若 256MB 可保留 ---
CONFIG_KERNEL_ZRAM_BACKEND_LZO=n           # 视内存大小决定
CONFIG_KERNEL_ZRAM_DEF_COMP_LZORLE=n

# libcurl 精简（只保留最基础功能）
# 若用 wget 或 curl 只需 HTTP/HTTPS，其他全关
CONFIG_LIBCURL_COOKIES=n                   # 关
CONFIG_LIBCURL_CRYPTO_AUTH=n               # 关
CONFIG_LIBCURL_FILE=n                      # 关
CONFIG_LIBCURL_FTP=n                       # 关
CONFIG_LIBCURL_HTTP=y                      # 保留 HTTP
CONFIG_LIBCURL_NGHTTP2=n                   # 若不用 HTTP/2 可关
CONFIG_LIBCURL_OPENSSL=y                   # 保留 HTTPS（OpenSSL 后端）
CONFIG_LIBCURL_PROXY=n                     # 关
CONFIG_LIBCURL_TFTP=n                      # 关
CONFIG_LIBCURL_THREADED_RESOLVER=n         # 关
CONFIG_LIBCURL_TLS_SRP=n                   # 关
CONFIG_LIBCURL_UNIX_SOCKETS=n              # 关

#LuCI 中文支持
CONFIG_LUCI_LANG_zh_Hans=y                 # 保留，Web 管理用中文

#NSS 硬件加速
CONFIG_NSS_DRV_IGS_ENABLE=y
CONFIG_NSS_DRV_L2TP_ENABLE=y
CONFIG_NSS_DRV_LAG_ENABLE=y
CONFIG_NSS_DRV_MAPT_ENABLE=y
CONFIG_NSS_DRV_PPTP_ENABLE=y
CONFIG_NSS_DRV_PVXLAN_ENABLE=y
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_VXLAN_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y
# CONFIG_NSS_FIRMWARE_VERSION_12_5 is not set

# IPv6 过渡技术
CONFIG_PACKAGE_6rd=y    #6RD隧道，通过IPv4传IPv6

# 文件系统扩展属性工具
CONFIG_PACKAGE_attr=m    #管理文件扩展属性

# Avahi 零配置网络
# CONFIG_PACKAGE_avahi-dbus-daemon is not set    #mDNS/DNS-SD守护进程，局域网设备发现

# 块设备挂载
CONFIG_PACKAGE_block-mount=y    #挂载USB硬盘/U盘等存储设备

# Boost C++ 库
CONFIG_PACKAGE_boost=m    #Boost基础库
CONFIG_PACKAGE_boost-program_options=m    #命令行参数解析
CONFIG_PACKAGE_boost-system=m    #系统相关功能（错误码等）

# Btrfs 文件系统
CONFIG_PACKAGE_btrfs-progs=m    #Btrfs管理工具
CONFIG_PACKAGE_kmod-fs-btrfs=m    #Btrfs内核模块
CONFIG_PACKAGE_kmod-lib-raid6=m    #RAID6计算库
CONFIG_PACKAGE_kmod-lib-xor=m    #XOR计算库
CONFIG_PACKAGE_kmod-lib-zstd=m    #Zstd压缩库

# CA 证书
CONFIG_PACKAGE_ca-certificates=m    #HTTPS信任链证书

# CGI-I/O 接口
CONFIG_PACKAGE_cgi-io=y    #LuCI文件上传/下载

# ChinaDNS-NG
CONFIG_PACKAGE_chinadns-ng=y    #DNS防污染

# Coreutils GNU工具集
CONFIG_PACKAGE_coreutils=m    #GNU核心工具集合
CONFIG_PACKAGE_coreutils-base64=m    #base64编码解码
CONFIG_PACKAGE_coreutils-nohup=m    #后台运行命令

# Curl 网络传输
CONFIG_PACKAGE_curl=m    #支持HTTP/HTTPS/FTP的文件下载工具

# DBus 消息总线
CONFIG_PACKAGE_dbus=m    #进程间通信

# DDNS 动态域名解析
CONFIG_PACKAGE_ddns-scripts=y    #DDNS基础脚本
CONFIG_PACKAGE_ddns-scripts-services=y    #DDNS服务商列表
CONFIG_PACKAGE_luci-app-ddns=y    #DDNS管理界面

# 默认设置
CONFIG_PACKAGE_default-settings=y    #基础默认配置
CONFIG_PACKAGE_default-settings-chn=y    #中国区优化（时区/源等）

# DNS 代理/转发
CONFIG_PACKAGE_dns2socks=m    #DNS经SOCKS代理转发
CONFIG_PACKAGE_dns2tcp=m    #DNS经TCP转发（防污染）

# Docker 容器引擎（全部移除）
# CONFIG_PACKAGE_docker is not set    #Docker CLI客户端
# CONFIG_PACKAGE_docker-compose is not set    #Docker多容器编排
# CONFIG_PACKAGE_dockerd is not set    #Docker守护进程
# CONFIG_PACKAGE_luci-app-dockerman is not set    #Docker管理界面
# CONFIG_PACKAGE_luci-lib-docker is not set    #Docker LuCI库
# CONFIG_PACKAGE_runc is not set    #OCI容器运行时
# CONFIG_PACKAGE_tini is not set    #init进程替代
# CONFIG_PACKAGE_containerd is not set    #Containerd容器运行时
# CONFIG_PACKAGE_cgroupfs-mount is not set    #Cgroupfs挂载工具
# CONFIG_PACKAGE_kmod-br-netfilter is not set    #桥接过滤（Docker需要，已移除）
# CONFIG_PACKAGE_kmod-veth is not set    #Virtual Ethernet设备对（已移除）


# 网络唤醒
CONFIG_PACKAGE_etherwake=y    #发送魔术包唤醒局域网设备
CONFIG_PACKAGE_luci-app-wol=y    #WOL管理界面

# 防火墙
CONFIG_PACKAGE_firewall=m    #传统iptables防火墙
CONFIG_PACKAGE_luci-app-firewall=y    #防火墙管理界面

# IP地理信息查看
CONFIG_PACKAGE_geoview=m    #查看IP地理位置

# Hysteria 代理
CONFIG_PACKAGE_hysteria=m    #基于魔改QUIC的抗丢包代理

# IP 工具集
CONFIG_PACKAGE_ip-full=m    #完整版ip命令（隧道/策略路由）
CONFIG_PACKAGE_ip-tiny=y    #精简版ip命令

# IPv6 防火墙
CONFIG_PACKAGE_ip6tables-nft=m    #IPv6 nftables兼容层
CONFIG_PACKAGE_kmod-ip6tables=m    #IPv6防火墙内核模块

# Iperf3 网络测速
CONFIG_PACKAGE_iperf3=y    #网络吞吐量测试
CONFIG_PACKAGE_libiperf3=y    #iperf3库

# ipt2socks 代理转发
CONFIG_PACKAGE_ipt2socks=m    #iptables流量转SOCKS代理

# iptables 扩展
CONFIG_PACKAGE_iptables-mod-extra=m    #额外匹配扩展
CONFIG_PACKAGE_iptables-mod-fullconenat=y    #全锥形NAT支持
CONFIG_PACKAGE_iptables-mod-ipopt=y    #IP选项匹配
CONFIG_PACKAGE_iptables-nft=y    #nftables版iptables

# 内核模块 - 网络功能
CONFIG_PACKAGE_kmod-bonding=y    #网卡绑定/链路聚合
CONFIG_PACKAGE_kmod-dummy=m    #虚拟网卡接口
CONFIG_PACKAGE_kmod-gre6=y    #IPv6 GRE隧道
CONFIG_PACKAGE_kmod-ifb=y    #中间功能块（流量整形）
CONFIG_PACKAGE_kmod-inet-diag=y    #TCP连接诊断
CONFIG_PACKAGE_kmod-ip6-tunnel=y    #IPv6隧道
CONFIG_PACKAGE_kmod-sit=y    #IPv6 over IPv4隧道
CONFIG_PACKAGE_kmod-macvlan=m    #MAC VLAN虚拟网卡
CONFIG_PACKAGE_kmod-vxlan=y    #VXLAN隧道
CONFIG_PACKAGE_kmod-wireguard=y    #WireGuard VPN
CONFIG_PACKAGE_kmod-tun=y    #TUN/TAP虚拟网卡
CONFIG_PACKAGE_kmod-netlink-diag=y    #Netlink套接字诊断

# 内核模块 - 加密/压缩
CONFIG_PACKAGE_kmod-crypto-acompress=y    #异步压缩
CONFIG_PACKAGE_kmod-crypto-blake2b=m    #BLAKE2b哈希
CONFIG_PACKAGE_kmod-crypto-crc32=y    #CRC32校验
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y    #ChaCha20加密
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y    #ChaCha20-Poly1305认证加密
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y    #Curve25519椭圆曲线
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y    #Poly1305消息认证
CONFIG_PACKAGE_kmod-crypto-xxhash=m    #xxHash哈希
CONFIG_PACKAGE_kmod-lib-lzo=y    #LZO压缩
CONFIG_PACKAGE_kmod-lib-xxhash=m    #xxHash库
CONFIG_PACKAGE_kmod-lib-zlib-deflate=m    #Zlib Deflate压缩
CONFIG_PACKAGE_kmod-lib-zlib-inflate=m    #Zlib Inflate解压

# 内核模块 - 文件系统
CONFIG_PACKAGE_kmod-fs-exportfs=y    #NFS导出支持
CONFIG_PACKAGE_kmod-fs-f2fs=y    #F2FS文件系统
CONFIG_PACKAGE_kmod-fs-ntfs3=y    #NTFS读写支持
CONFIG_PACKAGE_kmod-fs-vfat=y    #FAT32支持
CONFIG_PACKAGE_kmod-fs-xfs=y    #XFS文件系统

# 内核模块 - iptables/netfilter
CONFIG_PACKAGE_kmod-ipt-conntrack=y    #连接跟踪
CONFIG_PACKAGE_kmod-ipt-core=y    #iptables核心
CONFIG_PACKAGE_kmod-ipt-extra=m    #扩展匹配
CONFIG_PACKAGE_kmod-ipt-fullconenat=y    #全锥形NAT
CONFIG_PACKAGE_kmod-ipt-ipopt=y    #IP选项匹配
CONFIG_PACKAGE_kmod-ipt-ipset=y    #IP集合匹配
CONFIG_PACKAGE_kmod-ipt-nat=y    #NAT支持
CONFIG_PACKAGE_kmod-ipt-nat6=m    #IPv6 NAT
CONFIG_PACKAGE_kmod-ipt-physdev=m    #物理设备匹配
CONFIG_PACKAGE_kmod-iptunnel4=y    #IPv4隧道
CONFIG_PACKAGE_kmod-iptunnel6=y    #IPv6隧道
CONFIG_PACKAGE_kmod-nat46=y    #IPv4/IPv6转换
CONFIG_PACKAGE_kmod-nf-ipt=y    #IPv4过滤
CONFIG_PACKAGE_kmod-nf-ipt6=m    #IPv6过滤
CONFIG_PACKAGE_kmod-nf-ipvs=m    #IPVS负载均衡
CONFIG_PACKAGE_kmod-nf-nat6=m    #IPv6 NAT
CONFIG_PACKAGE_kmod-nf-socket=y    #socket匹配
CONFIG_PACKAGE_kmod-nf-tproxy=y    #透明代理
CONFIG_PACKAGE_kmod-nft-compat=y    #nftables兼容
CONFIG_PACKAGE_kmod-nft-socket=y    #nftables socket匹配
CONFIG_PACKAGE_kmod-nft-tproxy=y    #nftables透明代理

# 内核模块 - 字符集
CONFIG_PACKAGE_kmod-nls-cp437=y    #CP437编码
CONFIG_PACKAGE_kmod-nls-iso8859-1=y    #ISO-8859-1编码
CONFIG_PACKAGE_kmod-nls-utf8=y    #UTF-8编码

# 内核模块 - QCA NSS 高通网络加速
CONFIG_PACKAGE_kmod-qca-mcs=y    #MACsec控制
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y    #流量调度
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=y    #L2TP隧道加速
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y    #链路聚合管理
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y    #MAP-T转换加速
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y    #PPPoE加速
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y    #PPTP隧道加速
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y    #QoS队列加速
CONFIG_PACKAGE_kmod-qca-nss-macsec=y    #MACsec加密加速

# 内核模块 - QoS/流量整形
CONFIG_PACKAGE_kmod-sched-cake=y    #Cake队列算法
CONFIG_PACKAGE_kmod-sched-core=y    #QoS调度核心

# 内核模块 - SCSI/USB存储
CONFIG_PACKAGE_kmod-scsi-core=y    #SCSI核心
CONFIG_PACKAGE_kmod-usb-dwc2=y    #DWC2 USB控制器
CONFIG_PACKAGE_kmod-usb-dwc2-pci=y    #DWC2 PCI接口
CONFIG_PACKAGE_kmod-usb-ehci=y    #EHCI USB 2.0控制器
CONFIG_PACKAGE_kmod-usb-ohci=y    #OHCI USB 1.1控制器
CONFIG_PACKAGE_kmod-usb-ohci-pci=y    #OHCI PCI接口
CONFIG_PACKAGE_kmod-usb-phy-nop=y    #空PHY驱动
CONFIG_PACKAGE_kmod-usb-roles=y    #USB角色切换
CONFIG_PACKAGE_kmod-usb-serial=y    #USB串口
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y    #高通USB串口
CONFIG_PACKAGE_kmod-usb-serial-wwan=y    #WWAN USB串口
CONFIG_PACKAGE_kmod-usb-storage=y    #USB存储
CONFIG_PACKAGE_kmod-usb-storage-extras=y    #USB存储扩展
CONFIG_PACKAGE_kmod-usb-uhci=y    #UHCI USB 1.1控制器
CONFIG_PACKAGE_kmod-usb2=y    #USB 2.0
CONFIG_PACKAGE_kmod-usb2-pci=y    #USB 2.0 PCI接口

# ZRAM 内存压缩
CONFIG_PACKAGE_kmod-zram=y    #ZRAM内核模块
CONFIG_PACKAGE_zram-swap=y    #ZRAM交换管理

# 基础库
CONFIG_PACKAGE_libatomic=y    #原子操作库
CONFIG_PACKAGE_libattr=m    #扩展属性库
CONFIG_PACKAGE_libcap=y    #POSIX权限控制
CONFIG_PACKAGE_libcap-ng=y    #下一代权限控制
CONFIG_PACKAGE_libelf=m    #ELF文件处理
CONFIG_PACKAGE_libexpat=m    #XML解析
CONFIG_PACKAGE_liblua=y    #Lua脚本引擎
CONFIG_PACKAGE_libstdcpp=y    #C++标准库
CONFIG_PACKAGE_libuv=y    #异步I/O库
CONFIG_PACKAGE_libwebsockets-full=y    #WebSocket完整支持

# 网络相关库
CONFIG_PACKAGE_libavahi-client=m    #mDNS客户端
CONFIG_PACKAGE_libcurl=m    #URL传输库
CONFIG_PACKAGE_libdaemon=m    #守护进程库
CONFIG_PACKAGE_libgnutls=m    #SSL/TLS库
CONFIG_PACKAGE_libip4tc=y    #IPv4 iptables库
CONFIG_PACKAGE_libip6tc=y    #IPv6 iptables库
CONFIG_PACKAGE_libiptext=y    #iptables扩展库
CONFIG_PACKAGE_libiptext-nft=y    #nftables扩展库
CONFIG_PACKAGE_libiptext6=y    #IPv6 iptables扩展库
CONFIG_PACKAGE_libxtables=y    #xtables库
CONFIG_PACKAGE_libminiupnpc=y    #UPnP客户端
CONFIG_PACKAGE_libnatpmp=y    #NAT-PMP客户端
CONFIG_PACKAGE_libnghttp2=m    #HTTP/2库
